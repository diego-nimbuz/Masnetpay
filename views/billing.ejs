<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cobranza</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background: #2c3e50; color: white; position: fixed; width: 240px; z-index: 1000; transition: all 0.3s; }
        .sidebar a { color: white; text-decoration: none; padding: 15px; display: block; }
        .sidebar a:hover { background: #34495e; }
        .main-content { margin-left: 240px; padding: 30px; transition: all 0.3s; }
        .card { border: none; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); margin-bottom: 20px; }
        .paid { color: #198754; font-weight: bold; }
        .pending { color: #dc3545; font-weight: bold; }
        .table-success-light { background-color: #f0fff4 !important; }
        .logo-container { padding: 25px 15px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 10px; }
        .sidebar-logo { max-width: 100%; height: auto; max-height: 80px; object-fit: contain; border-radius: 4px; }
        .sort-icon { cursor: pointer; margin-left: 5px; color: #ccc; }
        .sort-icon.active { color: #0d6efd; }
        
        /* Ajustes Responsivos */
        @media (max-width: 768px) {
            .sidebar { width: 100%; height: auto; position: relative; }
            .main-content { margin-left: 0; padding: 15px; }
            .h1 { font-size: 1.5rem; }
            .w-100-mobile { width: 100% !important; }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 sidebar">
                <div class="position-sticky pt-3">
                    <div class="logo-container">
                        <img src="/img/logo.png" alt="MASNET Logo" class="sidebar-logo">
                    </div>
                    <a href="/">Panel de Control</a>
                    <a href="/customers">Clientes</a>
                    <a href="/logs">Historial de Envíos</a>
                    <a href="/billing">Cobranza</a>
                    <a href="/packages">Paquetes</a>
                    <a href="/settings">Configuración</a>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="main-content col-md-10">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <h1>Módulo de Cobranza</h1>
                    <div class="card bg-light border-primary">
                        <div class="card-body p-2 d-flex gap-3 align-items-center flex-wrap">
                            <span class="fw-bold text-primary"><i class="bi bi-file-earmark-pdf"></i> Generar Reporte:</span>
                            <form action="/billing" method="GET" class="d-flex gap-2 align-items-center">
                                <input type="date" name="startDate" class="form-control form-control-sm" value="<%= startDate %>">
                                <input type="date" name="endDate" class="form-control form-control-sm" value="<%= endDate %>">
                                <button type="submit" class="btn btn-sm btn-primary">Filtrar</button>
                            </form>
                            <a href="/report-billing-pdf?startDate=<%= startDate %>&endDate=<%= endDate %>" class="btn btn-sm btn-success">Descargar PDF</a>
                            <a href="/report-billing-csv?startDate=<%= startDate %>&endDate=<%= endDate %>" class="btn btn-sm btn-primary">Descargar Excel</a>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4 col-sm-4 mb-2">
                        <div class="card text-center p-3 border-success border-2">
                            <h6 class="text-muted">Recaudado (Mes Actual)</h6>
                            <h3 class="text-success">$<%= currentTotal.toFixed(2) %></h3>
                        </div>
                    </div>
                    <div class="col-md-4 col-sm-4 mb-2">
                        <div class="card text-center p-3 border-primary border-2">
                            <h6 class="text-muted">Clientes Pagados</h6>
                            <h3 class="text-primary"><%= paidCustomersCount %></h3>
                        </div>
                    </div>
                    <div class="col-md-4 col-sm-4 mb-2">
                        <div class="card text-center p-3 border-danger border-2">
                            <h6 class="text-muted">Pendientes de Pago</h6>
                            <h3 class="text-danger"><%= pendingCustomers.length %></h3>
                        </div>
                    </div>
                </div>

                <% if (typeof isDefaultView !== 'undefined' && !isDefaultView) { %>
                <div class="alert alert-info py-2 small mb-4 shadow-sm border-0 d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Viendo reporte de cobranza del <strong><%= startDate %></strong> al <strong><%= endDate %></strong>. 
                        Total recaudado en este periodo: <strong>$<%= reportTotal.toFixed(2) %></strong>.
                    </div>
                    <a href="/billing" class="btn btn-sm btn-outline-info">Volver a Mes Actual</a>
                </div>
                <% } %>

                <!-- Registro de Pago -->
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-cash-stack"></i> Registrar Pago del Mes Actual</h5>
                    </div>
                    <div class="card-body">
                        <form action="/register-payment" method="POST" class="row g-3" id="paymentForm">
                            <input type="hidden" name="currentStartDate" value="<%= startDate %>">
                            <input type="hidden" name="currentEndDate" value="<%= endDate %>">
                            <div class="col-md-4 col-12">
                                <label class="form-label fw-bold">1. Buscar Cliente Pendiente</label>
                                <div class="input-group mb-2">
                                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                                    <input type="text" id="customerSearch" class="form-control form-control-sm" placeholder="Nombre o Suscriptor...">
                                </div>
                                <select name="customer_id" id="customerSelect" class="form-select" required>
                                    <option value="">Elegir cliente...</option>
                                    <% pendingCustomers.forEach(customer => { %>
                                        <% 
                                            const lateFrom = moment(customer.early_pay_date).add(6, 'days');
                                            const isLate = moment(today).isSameOrAfter(lateFrom, 'day');
                                        %>
                                        <option value="<%= customer.id %>" 
                                                 data-search="<%= customer.subscriber_number %> <%= customer.name %>"
                                                 data-late="<%= isLate %>"
                                                 class="<%= isLate ? 'text-danger fw-bold' : '' %>">
                                             <%= customer.subscriber_number %> - <%= customer.name %> 
                                             <%= isLate ? ' (⚠️ ATRASADO)' : '' %>
                                         </option>
                                    <% }) %>
                                </select>
                                <div id="latePaymentWarning" class="alert alert-warning p-1 mt-2 small d-none">
                                    <i class="bi bi-exclamation-triangle"></i> Pago retrasado detectado.
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <label class="form-label fw-bold">2. Tipo de Pago</label>
                                <select name="payment_type" class="form-select" required id="paymentTypeSelect">
                                    <option value="Pronto Pago">Pronto Pago</option>
                                    <option value="Pago Normal">Pago Normal</option>
                                    <option value="Corte de Servicio">Corte de Servicio</option>
                                </select>
                            </div>
                            <div class="col-md-2 col-6">
                                <label class="form-label fw-bold">3. Monto</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" step="0.01" name="amount" class="form-control" id="paymentAmountInput" required>
                                </div>
                            </div>
                            <div class="col-md-3 col-12">
                                <label class="form-label fw-bold">4. Fecha Real del Pago</label>
                                <input type="date" name="payment_date" id="paymentDateInput" class="form-control" value="<%= today %>" required>
                            </div>
                            <div class="col-12 text-end">
                                <button type="submit" class="btn btn-success btn-lg w-100-mobile">
                                    <i class="bi bi-check-circle"></i> Registrar Pago
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Tabla de Estado de Cobranza -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 text-dark">Control de Cobranza - Mes Actual</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle" id="billingTable">
                                <thead class="table-light">
                                    <tr>
                                        <th data-sort="0">Suscriptor <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th data-sort="1">Nombre <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th class="d-none d-sm-table-cell" data-sort="2">Pronto Pago (Inicio) <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th class="d-none d-sm-table-cell" data-sort="3">Pago Normal <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th class="d-none d-sm-table-cell" data-sort="4">Corte <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th class="text-center" data-sort="5">Estado Mes <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th data-sort="6">Monto Recibido <i class="bi bi-arrow-down-up sort-icon"></i></th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% allCustomers.forEach(customer => { %>
                                        <% 
                                            const preferredDay = customer.preferred_payment_day || moment(customer.early_pay_date).date();
                                            const targetDay = Math.min(preferredDay, moment().daysInMonth());
                                            const cycle = moment().date(targetDay).format('YYYY-MM-DD');
                                            const customerPayments = currentMonthPayments.filter(p => p.customer_id === customer.id);
                                            const cyclePayment = customerPayments.find(p => p.billing_cycle === cycle) || (customerPayments.length === 1 ? customerPayments[0] : null);
                                            const isPaid = !!cyclePayment;
                                            const latePayments = customerPayments.filter(p => p.billing_cycle && p.billing_cycle !== cycle);
                                            const totalReceived = customerPayments.reduce((acc, p) => acc + (p.amount || 0), 0);
                                        %>
                                        <tr class="<%= isPaid ? 'table-success-light' : '' %>">
                                            <td><span class="badge bg-secondary"><%= customer.subscriber_number %></span></td>
                                            <td class="fw-bold"><%= customer.name %></td>
                                            <td class="d-none d-sm-table-cell small" data-sort-value="<%= customer.early_pay_date %>"><%= fDate(customer.early_pay_date) %></td>
                                            <td class="d-none d-sm-table-cell small" data-sort-value="<%= customer.normal_pay_date %>"><%= fDate(customer.normal_pay_date) %></td>
                                            <td class="d-none d-sm-table-cell small" data-sort-value="<%= customer.service_cut_date %>"><%= fDate(customer.service_cut_date) %></td>
                                            <td class="text-center" data-sort-value="<%= isPaid ? 1 : 0 %>">
                                                <% if (isPaid) { %>
                                                    <span class="badge rounded-pill bg-success px-3">PAGADO</span>
                                                <% } else { %>
                                                    <span class="badge rounded-pill bg-danger px-3">PENDIENTE</span>
                                                    <% 
                                                        const todayStr = new Date().toISOString().split('T')[0];
                                                        if (todayStr >= customer.service_cut_date) {
                                                    %>
                                                        <div class="text-danger fw-bold mt-1" style="font-size: 0.7rem;">TIENE CORTE</div>
                                                    <% } %>
                                                <% } %>
                                            </td>
                                            <td data-sort-value="<%= totalReceived.toFixed(2) %>">
                                                <% if (customerPayments.length > 0) { %>
                                                    <div class="fw-bold">$<%= totalReceived.toFixed(2) %></div>
                                                    <div class="text-muted small" style="font-size: 0.7rem;">
                                                        <% customerPayments.forEach(p => { %>
                                                            <div>
                                                                $<%= (p.amount || 0).toFixed(2) %> | <%= p.payment_type %> | <%= fDate(p.payment_date) %>
                                                                <% if (p.billing_cycle && p.billing_cycle !== cycle) { %>
                                                                    <span class="text-danger fw-bold">ATRASADO</span>
                                                                <% } %>
                                                            </div>
                                                        <% }) %>
                                                    </div>
                                                <% } else { %>
                                                    <span class="text-muted">---</span>
                                                <% } %>
                                            </td>
                                            <td class="text-end">
                                                <% if (isPaid) { %>
                                                    <form action="/delete-payment/<%= cyclePayment.id %>" method="POST" onsubmit="return confirm('¿Borrar este pago? Se revertirán las fechas al ciclo anterior.')" class="d-inline">
                                                        <input type="hidden" name="startDate" value="<%= startDate %>">
                                                        <input type="hidden" name="endDate" value="<%= endDate %>">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Borrar pago">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                <% } %>
                                                <% latePayments.forEach(p => { %>
                                                    <form action="/edit-late-payment/<%= p.id %>" method="POST" class="d-inline edit-late-payment-form" data-current-amount="<%= (p.amount || 0).toFixed(2) %>">
                                                        <input type="hidden" name="startDate" value="<%= startDate %>">
                                                        <input type="hidden" name="endDate" value="<%= endDate %>">
                                                        <input type="hidden" name="amount" value="">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary border-0" title="Editar monto pago atrasado">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </button>
                                                    </form>
                                                <% }) %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Lógica para poner automáticamente el monto según el tipo de pago
        const customersData = <%- JSON.stringify(allCustomers) %>;
        const typeSelect = document.getElementById('paymentTypeSelect');
        const amountInput = document.getElementById('paymentAmountInput');
        const customerSelect = document.getElementById('customerSelect');
        const customerSearch = document.getElementById('customerSearch');
        const paymentForm = document.getElementById('paymentForm');
        const paymentDateInput = document.getElementById('paymentDateInput');
        const lateWarning = document.getElementById('latePaymentWarning');

        // Funcionalidad de búsqueda en el select
        customerSearch.addEventListener('input', function() {
            const filter = this.value.toLowerCase();
            const options = customerSelect.options;
            
            for (let i = 1; i < options.length; i++) { // Empezamos en 1 para saltar "Elegir..."
                const text = options[i].getAttribute('data-search').toLowerCase();
                if (text.includes(filter)) {
                    options[i].style.display = "";
                } else {
                    options[i].style.display = "none";
                }
            }
        });

        function updateSuggestedAmount() {
            const customerId = parseInt(customerSelect.value);
            const type = typeSelect.value;
            const selectedOption = customerSelect.options[customerSelect.selectedIndex];
            
            if (!customerId) {
                amountInput.value = '';
                lateWarning.classList.add('d-none');
                return;
            }

            // Mostrar/ocultar aviso de retraso
            const isLate = selectedOption.getAttribute('data-late') === 'true';
            if (isLate) {
                lateWarning.classList.remove('d-none');
            } else {
                lateWarning.classList.add('d-none');
            }

            const customer = customersData.find(c => c.id === customerId);
            
            if (customer) {
                let amount = 0;
                if (type === 'Pronto Pago') amount = customer.early_pay_amount;
                else if (type === 'Pago Normal') amount = customer.normal_pay_amount;
                else if (type === 'Corte de Servicio') amount = customer.service_cut_amount;
                
                amountInput.value = amount ? amount.toFixed(2) : '0.00';
            }
        }

        // Validación de fechas antes de enviar
        paymentForm.addEventListener('submit', function(e) {
            const customerId = parseInt(customerSelect.value);
            const type = typeSelect.value;
            const selectedDate = paymentDateInput.value;
            
            const customer = customersData.find(c => c.id === customerId);
            
            if (customer) {
                let scheduledDate = '';
                if (type === 'Pronto Pago') scheduledDate = customer.early_pay_date;
                else if (type === 'Pago Normal') scheduledDate = customer.normal_pay_date;
                else if (type === 'Corte de Servicio') scheduledDate = customer.service_cut_date;

                if (selectedDate !== scheduledDate) {
                    const confirmMsg = `¡Aviso! La fecha seleccionada (${selectedDate}) no coincide con la fecha programada para ${type} de este cliente (${scheduledDate}).\n\n¿Deseas registrar el pago de todas formas?`;
                    if (!confirm(confirmMsg)) {
                        e.preventDefault(); // Detener el envío si el usuario cancela
                    }
                }
            }
        });

        typeSelect.addEventListener('change', updateSuggestedAmount);
        customerSelect.addEventListener('change', updateSuggestedAmount);
        
        // Ejecutar una vez al cargar por si ya hay valores seleccionados
        window.addEventListener('load', updateSuggestedAmount);

        document.querySelectorAll('.edit-late-payment-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                const currentAmount = this.getAttribute('data-current-amount') || '';
                const entered = prompt('Nuevo monto para el pago atrasado:', currentAmount);
                if (entered === null) {
                    e.preventDefault();
                    return;
                }
                const parsed = Number(entered);
                if (!Number.isFinite(parsed)) {
                    e.preventDefault();
                    alert('Monto inválido');
                    return;
                }
                const amountInputHidden = this.querySelector('input[name=\"amount\"]');
                amountInputHidden.value = parsed.toFixed(2);
            });
        });
    </script>

    <script>
        function enableTableSorting(table) {
            const headers = table.querySelectorAll('th[data-sort]');
            headers.forEach(header => {
                header.addEventListener('click', () => {
                    const tbody = table.querySelector('tbody');
                    const index = Number(header.getAttribute('data-sort'));
                    const currentDir = header.getAttribute('data-sort-dir') || 'desc';
                    const nextDir = currentDir === 'asc' ? 'desc' : 'asc';

                    table.querySelectorAll('th').forEach(th => {
                        th.classList.remove('sort-asc', 'sort-desc');
                        th.removeAttribute('data-sort-dir');
                        const icon = th.querySelector('.sort-icon');
                        if (icon) icon.classList.remove('active');
                    });

                    header.setAttribute('data-sort-dir', nextDir);
                    header.classList.add(nextDir === 'asc' ? 'sort-asc' : 'sort-desc');
                    const activeIcon = header.querySelector('.sort-icon');
                    if (activeIcon) activeIcon.classList.add('active');

                    const rows = Array.from(tbody.querySelectorAll('tr'));
                    const sortedRows = rows.sort((a, b) => {
                        const aCell = a.cells[index];
                        const bCell = b.cells[index];
                        const aRaw = aCell?.getAttribute('data-sort-value') ?? aCell?.textContent ?? '';
                        const bRaw = bCell?.getAttribute('data-sort-value') ?? bCell?.textContent ?? '';
                        const aText = String(aRaw).trim();
                        const bText = String(bRaw).trim();

                        const aDate = /^\d{4}-\d{2}-\d{2}$/.test(aText) ? Date.parse(`${aText}T00:00:00`) : NaN;
                        const bDate = /^\d{4}-\d{2}-\d{2}$/.test(bText) ? Date.parse(`${bText}T00:00:00`) : NaN;
                        if (!Number.isNaN(aDate) && !Number.isNaN(bDate)) {
                            return nextDir === 'asc' ? aDate - bDate : bDate - aDate;
                        }

                        const aNumMatch = aText.replace(/,/g, '').match(/-?\d+(\.\d+)?/);
                        const bNumMatch = bText.replace(/,/g, '').match(/-?\d+(\.\d+)?/);
                        const aNum = aNumMatch ? Number(aNumMatch[0]) : NaN;
                        const bNum = bNumMatch ? Number(bNumMatch[0]) : NaN;
                        if (Number.isFinite(aNum) && Number.isFinite(bNum)) {
                            return nextDir === 'asc' ? aNum - bNum : bNum - aNum;
                        }

                        return nextDir === 'asc'
                            ? aText.localeCompare(bText, 'es', { numeric: true, sensitivity: 'base' })
                            : bText.localeCompare(aText, 'es', { numeric: true, sensitivity: 'base' });
                    });

                    tbody.append(...sortedRows);
                });
            });
        }

        const billingTable = document.getElementById('billingTable');
        if (billingTable) enableTableSorting(billingTable);
    </script>
</body>
</html>
