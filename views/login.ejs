<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp - Vincular Servicio</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .login-card { width: 100%; max-width: 400px; padding: 2rem; border-radius: 1rem; border: none; box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1); background: white; text-align: center; }
        .qr-image { max-width: 250px; margin: 1.5rem auto; border: 1px solid #eee; padding: 10px; border-radius: 8px; }
        .loading-spinner { margin: 2rem; }
        .whatsapp-brand { color: #25D366; font-weight: bold; font-size: 1.5rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="whatsapp-brand">
            <i class="bi bi-whatsapp"></i> MASNET - WhatsApp
        </div>
        
        <h5 class="mb-3">Vincular Dispositivo</h5>
        
        <% if (qr) { %>
            <p class="text-muted small">Escanea el código QR con tu celular en WhatsApp > Dispositivos vinculados.</p>
            <img src="<%= qr %>" alt="QR Code" class="qr-image">
            <div class="alert alert-info py-2 small">
                El sistema se actualizará automáticamente una vez vinculado.
            </div>
        <% } else { %>
            <div class="loading-spinner">
                <div class="spinner-border text-success" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p class="mt-3 text-muted">Esperando código QR...</p>
                <p class="small text-secondary">Si ya escaneaste el código, espera un momento a que se inicie la sesión.</p>
            </div>
        <% } %>

        <button onclick="window.location.reload()" class="btn btn-outline-success btn-sm mt-3">
            Actualizar Estado
        </button>
    </div>

    <script>
        // Auto recarga cada 5 segundos para verificar si ya está listo o hay nuevo QR
        setTimeout(() => {
            window.location.reload();
        }, 5000);
    </script>
</body>
</html>