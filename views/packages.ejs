<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paquetes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background: #2c3e50; color: white; position: fixed; width: 240px; z-index: 1000; transition: all 0.3s; }
        .sidebar a { color: white; text-decoration: none; padding: 15px; display: block; }
        .sidebar a:hover { background: #34495e; }
        .main-content { margin-left: 240px; padding: 30px; transition: all 0.3s; }
        .card { border: none; box-shadow: 0 .125rem .25rem rgba(0,0,0,.075); }
        @media (max-width: 768px) {
            .sidebar { width: 100%; height: auto; position: relative; }
            .main-content { margin-left: 0; padding: 15px; }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 sidebar">
                <div class="position-sticky pt-3">
                    <div class="logo-container text-center p-3 border-bottom border-secondary">
                        <img src="/img/logo.png" alt="MASNET Logo" class="sidebar-logo" style="max-width: 100%; max-height: 80px;">
                    </div>
                    <a href="/">Panel de Control</a>
                    <a href="/customers">Clientes</a>
                    <a href="/logs">Historial de Envíos</a>
                    <a href="/billing">Cobranza</a>
                    <a href="/packages">Paquetes</a>
                    <a href="/settings">Configuración</a>
                </div>
            </nav>

            <main class="main-content col-md-10">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <h1 class="h3">Gestión de Paquetes</h1>
                </div>

                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header bg-white">
                                <strong>Paquetes Registrados</strong>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Nombre</th>
                                                <th class="text-end">Pronto</th>
                                                <th class="text-end">Normal</th>
                                                <th class="text-end">Corte</th>
                                                <th class="text-end">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% packages.forEach(p => { %>
                                                <tr>
                                                    <td class="fw-bold"><%= p.name %></td>
                                                    <td class="text-end">$<%= (p.early_pay_amount || 0).toFixed(2) %></td>
                                                    <td class="text-end">$<%= (p.normal_pay_amount || 0).toFixed(2) %></td>
                                                    <td class="text-end">$<%= (p.service_cut_amount || 0).toFixed(2) %></td>
                                                    <td class="text-end">
                                                        <div class="btn-group">
                                                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editPkgModal" data-id="<%= p.id %>" data-name="<%= p.name %>" data-early="<%= p.early_pay_amount %>" data-normal="<%= p.normal_pay_amount %>" data-cut="<%= p.service_cut_amount %>">Editar</button>
                                                            <form action="/packages/delete/<%= p.id %>" method="POST" onsubmit="return confirm('¿Eliminar este paquete?');">
                                                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="card">
                            <div class="card-header bg-white">
                                <strong>Nuevo Paquete</strong>
                            </div>
                            <div class="card-body">
                                <form action="/packages/add" method="POST" class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label">Nombre del Paquete</label>
                                        <input type="text" name="name" class="form-control" placeholder="Ej: Básico, Premium" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Pronto Pago</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" step="0.01" name="early_pay_amount" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Pago Normal</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" step="0.01" name="normal_pay_amount" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Corte</label>
                                        <div class="input-group">
                                            <span class="input-group-text">$</span>
                                            <input type="number" step="0.01" name="service_cut_amount" class="form-control" required>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary">Guardar Paquete</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <div class="modal fade" id="editPkgModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="editPkgForm" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">Editar Paquete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Paquete</label>
                            <input type="text" name="name" id="editPkgName" class="form-control" required>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Pronto Pago</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" step="0.01" name="early_pay_amount" id="editPkgEarly" class="form-control" required>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Pago Normal</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" step="0.01" name="normal_pay_amount" id="editPkgNormal" class="form-control" required>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Corte</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" step="0.01" name="service_cut_amount" id="editPkgCut" class="form-control" required>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const editPkgModal = document.getElementById('editPkgModal');
        editPkgModal.addEventListener('show.bs.modal', event => {
            const btn = event.relatedTarget;
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const early = btn.getAttribute('data-early');
            const normal = btn.getAttribute('data-normal');
            const cut = btn.getAttribute('data-cut');

            document.getElementById('editPkgForm').action = `/packages/edit/${id}`;
            document.getElementById('editPkgName').value = name || '';
            document.getElementById('editPkgEarly').value = early || '';
            document.getElementById('editPkgNormal').value = normal || '';
            document.getElementById('editPkgCut').value = cut || '';
        });
    </script>
</body>
</html>
